{
  "name": "libdpf",
  "version": "0.1.0",
  "type": "module",
  "description": "Distributed Point Function (DPF) library - TypeScript implementation with browser support",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "browser": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-specifier-resolution=node dist/test/dpf.test.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "cryptography",
    "dpf",
    "fss",
    "pir",
    "privacy",
    "browser",
    "web-crypto"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/aes-js": "^3.1.4",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "aes-js": "^3.1.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/weikengchen/libdpf.git"
  }
}
